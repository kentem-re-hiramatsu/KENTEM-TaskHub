{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!generators/**/*",
      "!ks-react-components/**/*",
      "!panda.config.ts",
      "!config/**/*.ts",
      "!auth.ts",
      "!public/mockServiceWorker.js",
      "!public/pdf.worker.min.mjs",
      "!.claude/worktrees/**/*"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "crlf"
  },
  "linter": {
    "rules": {
      "recommended": true,
      "complexity": {},
      "correctness": {
        "useImportExtensions": "off",
        "noUndeclaredDependencies": "off",
        "noNodejsModules": "off",
        "noUnusedImports": {
          "level": "error",
          "fix": "safe"
        },
        "noUnusedVariables": {
          "level": "error",
          "fix": "none"
        }
      },
      "nursery": {
        "useExplicitType": "off"
      },
      "performance": {
        "noReExportAll": "off",
        "noBarrelFile": "off",
        "useTopLevelRegex": "off"
      },
      "security": {
        "noSecrets": "off"
      },
      "style": {
        "useBlockStatements": "off",
        "noDefaultExport": "off",
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "filenameCases": ["kebab-case"]
          }
        },
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false,
            "conventions": [
              {
                "selector": { "kind": "typeLike" },
                "formats": ["PascalCase"]
              },
              {
                "selector": { "kind": "typeMember" },
                "formats": ["camelCase"]
              }
            ]
          }
        },
        "noParameterAssign": "error",
        "useAsConstAssertion": "error",
        "useDefaultParameterLast": "error",
        "useEnumInitializers": "error",
        "useSelfClosingElements": "error",
        "useSingleVarDeclarator": "error",
        "noUnusedTemplateLiteral": "error",
        "useNumberNamespace": "error",
        "noInferrableTypes": "error",
        "noUselessElse": "error",
        "useComponentExportOnlyModules": "off",
        "noCommonJs": "off",
        "noProcessEnv": "off",
        "noImplicitBoolean": "error"
      },
      "suspicious": {
        "noReactSpecificProps": "off",
        "noConsole": "off",
        "noArrayIndexKey": "off",
        "useStrictMode": "off"
      },
      "a11y": {
        "noStaticElementInteractions": "off",
        "useAriaPropsSupportedByRole": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "overrides": [
    {
      "includes": [
        "**/features/**/*.tsx",
        "**/components/**/*.tsx",
        "!**/features/**/*.stories.tsx",
        "!**/components/**/*.stories.tsx"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "warn",
            "useNodejsImportProtocol": "off"
          }
        }
      }
    },
    {
      "includes": ["proxy.ts", "lib/api-client.ts", "lib/api-fetch.ts"],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    }
  ]
}
