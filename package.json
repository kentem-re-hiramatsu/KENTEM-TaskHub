{
  "name": "kentem-taskhub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev --experimental-https",
    "dev:mock": "cross-env NEXT_PUBLIC_MSW=true PROXY_DISABLED=true run-s dev",
    "build": "next build",
    "start": "next start",
    "prepare": "panda codegen",
    "biome": "biome check",
    "biome:fix": "biome check --write",
    "typecheck": "tsc --noEmit",
    "check": "run-s biome build",
    "test": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "plop": "plop",
    "playwright": "playwright test",
    "playwright:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@pandacss/dev": "^1.8.2",
    "@playwright/test": "^1.56.1",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-vitest": "^10.2.8",
    "@storybook/nextjs-vite": "^10.2.8",
    "@storybook/react": "^10.2.8",
    "@types/encoding-japanese": "^2.2.1",
    "@types/node": "^20",
    "@types/nprogress": "^0.2.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "knip": "^5.85.0",
    "msw": "^2.12.10",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.2",
    "plop": "^4.0.5",
    "storybook": "^10.2.8",
    "typescript": "^5",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@tanstack/react-query": "^5.90.21",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "encoding-japanese": "^2.2.0",
    "exceljs": "^4.4.0",
    "next": "^16.2.1",
    "nprogress": "^0.2.0",
    "nuqs": "^2.8.8",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0",
    "zod": "^3.25.0",
    "zustand": "^5.0.12"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
